# =============================================================================
# Adapty Daily Report Bot — шаблон переменных окружения
# Скопируйте в .env и заполните значения. На Railway задавайте переменные в UI.
# =============================================================================

# --- Telegram ---
# Токен бота от @BotFather (например: 123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx)
TELEGRAM_BOT_TOKEN=

# Chat ID чата/канала, куда отправлять отчёт (число, для групп — отрицательное)
# Как получить: написать боту в чат → https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# (Опционально) ID топика в группе с темами. Если задан — отчёт уходит в этот топик.
# Как получить: отправьте в нужный топик сообщение, затем откройте getUpdates — в сообщении будет message_thread_id.
# TELEGRAM_TOPIC_ID=

# (Опционально) Управление только из лички: ваш Telegram user ID. Если задан — команды (/start, Собрать данные,
# время) бот принимает только в личном чате с вами; отчёты по-прежнему уходят в группу, в группе никто не видит команд.
# Как получить: напишите боту в личку, откройте https://api.telegram.org/bot<TOKEN>/getUpdates — в message.from.id будет ваш id.
TELEGRAM_ADMIN_ID=

# --- Adapty: приложение 1 ---
# Secret API Key из Adapty: App Settings → Secret key (для первого приложения)
ADAPTY_API_KEY_APP1=
# Отображаемое имя приложения в отчёте (например: My App iOS)
ADAPTY_APP_NAME_1=

# --- Adapty: приложение 2 ---
ADAPTY_API_KEY_APP2=
ADAPTY_APP_NAME_2=

# --- Adapty: приложение 3 ---
ADAPTY_API_KEY_APP3=
ADAPTY_APP_NAME_3=

# --- Опционально ---
# Часовой пояс в проекте зафиксирован как Europe/Minsk (планировщик + сбор данных Adapty)
# TZ и ADAPTY_TZ не используются.

# Время ежедневной отправки (часы:минуты по выбранному поясу, по умолчанию 09:00)
# REPORT_TIME=09:00

# Базовый URL Adapty Export Analytics API (по умолчанию api-admin.adapty.io)
# ADAPTY_API_BASE_URL=https://api-admin.adapty.io

# Путь к эндпоинту analytics (по умолчанию api/v1/client-api/metrics/analytics/)
# ADAPTY_ANALYTICS_PATH=api/v1/client-api/metrics/analytics/

# Путь к эндпоинту funnel (по умолчанию api/v1/client-api/metrics/funnel/)
# ADAPTY_FUNNEL_PATH=api/v1/client-api/metrics/funnel/

# Путь к эндпоинту cohort (по умолчанию api/v1/client-api/metrics/cohort/)
# ADAPTY_COHORT_PATH=api/v1/client-api/metrics/cohort/

# --- A/B Test overview report ---
# Если true, бот отправит отдельный A/B-отчёт сразу после ежедневной сводки.
AB_TEST_REPORT_ENABLED=true
AB_TEST_APP_INDEX=1
AB_TEST_ID=
AB_TEST_NAME=Test paywall prices. 4.99/29.99 vs 5.99/39.99
AB_TEST_START_DATE=2026-07-10

AB_TEST_VARIANT_A_LABEL=A
AB_TEST_VARIANT_A_PAYWALL_ID=d6d24875-e330-4ad9-8ee0-841d3452a911
AB_TEST_VARIANT_A_PAYWALL_NAME=New Paywall Old Prices

AB_TEST_VARIANT_B_LABEL=B
AB_TEST_VARIANT_B_PAYWALL_ID=d6765d7f-eb06-42db-8d0d-ee21e2b41fe8
AB_TEST_VARIANT_B_PAYWALL_NAME=New Paywall New Prices

# Dashboard API identity used for experiment-scoped metrics.
# Keep the token only in Railway/local secrets; never commit its value.
ADAPTY_DASHBOARD_APP_ID=
ADAPTY_DASHBOARD_TOKEN=

# --- Apple Ads compact report ---
# Если true, бот отправит короткий Apple Ads отчёт третьим сообщением после ежедневной сводки и A/B отчёта.
APPLE_ADS_REPORT_ENABLED=true
APPLE_ADS_APP_INDEX=1
APPLE_ADS_REPORT_TITLE=Unfollowers
APPLE_ADS_START_DATE=2026-06-01
APPLE_ADS_ATTRIBUTION_SOURCE=apple_search_ads

# Обязательно для корректного рекламного отчёта из Adapty Apple Ads Manager.
# Это dashboard auth token/company id, а не Secret API Key и не Developer CLI token.
# ADAPTY_DASHBOARD_TOKEN is shared with the A/B report configuration above.
# ADAPTY_DASHBOARD_COMPANY_ID=
# ADAPTY_DASHBOARD_APP_ID is shared with the A/B report configuration above.
# ADAPTY_ASA_API_BASE_URL=https://api-asa-admin.adapty.io/api/v1

# Опционально: если app internal id из Ads Manager уже известен, можно задать явно.
# Иначе бот попробует найти его через asa-metadata/apps-info.
# APPLE_ADS_INTERNAL_APP_ID=

# Опционально: fallback напрямую в Apple Ads API, если Adapty API не отдаёт spend.
# Нужны credentials из Apple Ads → Settings → API.
# APPLE_ADS_CLIENT_ID=
# APPLE_ADS_TEAM_ID=
# APPLE_ADS_KEY_ID=
# APPLE_ADS_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----"
# APPLE_ADS_ORG_ID=
# APPLE_ADS_ADAM_ID=
# APPLE_ADS_API_BASE_URL=https://api.searchads.apple.com/api/v5
