# =============================================================================
# Adapty Daily Report Bot — шаблон переменных окружения
# Скопируйте в .env и заполните значения. На Railway задавайте переменные в UI.
# =============================================================================

# --- Telegram ---
# Токен бота от @BotFather (например: 123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx)
TELEGRAM_BOT_TOKEN=

# Chat ID чата/канала, куда отправлять отчёт (число, для групп — отрицательное)
# Как получить: написать боту в чат → https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# --- Adapty: приложение 1 ---
# Secret API Key из Adapty: App Settings → Secret key (для первого приложения)
ADAPTY_API_KEY_APP1=
# Отображаемое имя приложения в отчёте (например: My App iOS)
ADAPTY_APP_NAME_1=

# --- Adapty: приложение 2 ---
ADAPTY_API_KEY_APP2=
ADAPTY_APP_NAME_2=

# --- Adapty: приложение 3 ---
ADAPTY_API_KEY_APP3=
ADAPTY_APP_NAME_3=

# --- Опционально ---
# Часовой пояс для отчёта и планировщика (IANA, по умолчанию Europe/Minsk)
# TZ=Europe/Minsk

# Время ежедневной отправки (часы:минуты по выбранному поясу, по умолчанию 09:00)
# REPORT_TIME=09:00

# Базовый URL Adapty API (если в документации указан другой — переопределите здесь)
# ADAPTY_API_BASE_URL=https://api.adapty.io
